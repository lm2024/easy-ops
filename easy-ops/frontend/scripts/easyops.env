# =============================================================================
# EasyOps 前端专用配置（仅前端那台机器使用，与 Server/Agent 无关）
# -----------------------------------------------------------------------------
# 私有化部署 - 推荐流程：
#   1. 在有 Node 的构建机上执行 build.sh 打出 dist
#   2. 把 dist/ + 本目录脚本 + easyops.env 拷到前端机器
#   3. 前端机器只需 Nginx（无需 Node、无需联网）
#
# 目录示例：
#   /data/easy-ops-frontend/
#     dist/              <- build.sh 产物
#     easyops.env
#     start.sh stop.sh restart.sh
#     nginx.conf         <- start.sh 按本配置自动生成
# =============================================================================

# 必改项：本机安装目录
INSTALL_DIR="${INSTALL_DIR:-}"

# 必改项：Server 内网地址（Nginx 反向代理 /api 和 /ws 到此处）
SERVER_API_URL="${SERVER_API_URL:-http://127.0.0.1:9091}"

# 可选项：前端监听端口
FRONTEND_PORT="${FRONTEND_PORT:-80}"

# 运行模式：
#   nginx  - 生产推荐，仅需 Nginx + dist（内网离线）
#   dev    - 开发：npm run dev（需源码和 node_modules）
#   preview- 本地预览 dist（需 Node，npm run preview）
SERVE_MODE="${SERVE_MODE:-nginx}"

# Nginx 可执行文件路径（留空则自动查找 nginx）
# NGINX_BIN=/usr/sbin/nginx
