# =============================================================================
# EasyOps Agent 专用配置（仅 Agent 那台机器使用，与 Server/前端无关）
# -----------------------------------------------------------------------------
# 【私有化部署】把本目录连同 jar 一起拷到 Agent 机器，只改下面【必改】项即可。
#
# 目录示例：
#   /data/easy-ops-agent/
#     easy-ops-agent.jar
#     easyops.env
#     start.sh  stop.sh  restart.sh
#     data/          ← 自动创建，存版本包、日志
# =============================================================================

# 【必改】本机在 Agent 上的安装目录
INSTALL_DIR="${INSTALL_DIR:-}"

# 【必改】Server 的内网地址（Agent 心跳、上报连这里）
AGENT_SERVER_URL="${AGENT_SERVER_URL:-http://192.168.1.10:8081/api}"

# 【必改】本节点名称（Server 节点列表里显示）
AGENT_NODE_NAME="${AGENT_NODE_NAME:-agent-node-1}"

# 【可选】Agent HTTP 端口
AGENT_PORT="${AGENT_PORT:-2123}"

# 【可选】Token，留空则启动时自动生成并打印到日志
# AGENT_TOKEN=

# 【可选】Java 路径
# JAVA_HOME=/usr/lib/jvm/java-8-openjdk-arm64

# 裸机自升级（无 Docker 内网生产保持 shell）
AGENT_RESTART_MODE="${AGENT_RESTART_MODE:-shell}"

# 【推荐】自升级时调用的重启脚本（Java 读取 agent.restart-script / AGENT_RESTART_SCRIPT）
# 默认使用本目录 start.sh，一般不用改
# AGENT_RESTART_SCRIPT=/data/easy-ops-agent/scripts/start.sh

# 【一般不用改】jar 文件名
AGENT_JAR_NAME="${AGENT_JAR_NAME:-easy-ops-agent.jar}"
