# =============================================================================
# EasyOps Server 专用配置（仅 Server 那台机器使用，与 Agent/前端无关）
# -----------------------------------------------------------------------------
# 【私有化部署】把本目录连同 jar 一起拷到 Server 机器，只改下面【必改】项即可。
#
# 目录示例（拷到目标机后）：
#   /data/easy-ops-server/
#     ops-platform-server.jar
#     easyops.env
#     start.sh  stop.sh  restart.sh
#     data/          ← 自动创建，存 H2、版本包、日志
# =============================================================================

# 【必改】本机在 Server 上的安装目录（jar 与脚本所在目录）
INSTALL_DIR="${INSTALL_DIR:-}"

# 【可选】HTTP 端口
SERVER_PORT="${SERVER_PORT:-8081}"

# 【可改】JWT 密钥 — 仅用于 SecurityConfig 启动校验，实际 token 由 SecureRandom 生成，非标准 JWT
# Agent（AGENT_TOKEN）和前端均与此值无关，≥32 字符即可
JWT_SECRET="${JWT_SECRET:-easy-ops-jwt-secret-change-me}"

# 【说明】Agent 机器上的数据根目录 —— Server 计算「部署到 Agent 的默认路径」时用
# 填 Agent 那台机器 easyops.env 里的 INSTALL_DIR/data，例如 /data/easy-ops-agent/data
AGENT_DATA_PATH="${AGENT_DATA_PATH:-/data/easy-ops-agent/data}"

# 【可选】Java 路径（ARM 内网若 java 不在 PATH）
# JAVA_HOME=/usr/lib/jvm/java-8-openjdk-arm64

# 【一般不用改】jar 文件名（与拷贝到目标机的文件名一致）
SERVER_JAR_NAME="${SERVER_JAR_NAME:-ops-platform-server.jar}"
