<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ops.server.mapper.KbImageMapper">
    <select id="findById" resultType="com.ops.common.model.KbImageModel">
        SELECT * FROM kb_image WHERE id = #{id}
    </select>
    <select id="findByDocumentId" resultType="com.ops.common.model.KbImageModel">
        SELECT * FROM kb_image WHERE document_id = #{documentId}
    </select>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO kb_image (document_id, file_name, file_path, file_size, mime_type, uploader_id, create_time)
        VALUES (#{documentId}, #{fileName}, #{filePath}, #{fileSize}, #{mimeType}, #{uploaderId}, #{createTime})
    </insert>
    <delete id="deleteByDocumentId">
        DELETE FROM kb_image WHERE document_id = #{documentId}
    </delete>
</mapper>
